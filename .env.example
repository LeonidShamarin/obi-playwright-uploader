# Bearer token, який Windmill використовує для дзвінків на цей сервер.
# Згенеруй через `openssl rand -hex 32` і пропиши в Coolify Application Secrets.
WORKER_BEARER_TOKEN=

# VTEX seller cabinet credentials.
VTEX_LOGIN_URL=https://hajus679.myvtex.com/_v/segment/admin-login/v1/login?returnUrl=%2Fadmin%2Fproducts
VTEX_LOGIN_USER=admin@boni-brands.com
VTEX_LOGIN_PASSWORD=

# Внутрішній OTP-сервер (для VTEX 2FA fallback).
OTP_SERVER_URL=http://88.198.203.52:9510
OTP_SERVER_TOKEN=
OTP_EMAIL=info@hajus-ag.com
OTP_PROVIDER=VTEX

# Google Sheets — OAuth-token JSON (з Windmill resource gsheets).
# Або вшити повний JSON, або path до файлу всередині контейнера.
GSHEETS_OAUTH_TOKEN_JSON=
GSHEETS_SPREADSHEET_ID=1d8s7eDyB3fbyNn2yvDf9TWbplM_tafnSFj4HGuMp52g
GSHEETS_SHEET_GID=590448179

# OBI-параметри
OBI_DEFAULT_CATEGORY=Sonstiges

# Persistent volume paths (вже встановлені у Dockerfile, не міняй без потреби)
STORAGE_STATE_PATH=/data/storage_state.json
SCREENSHOT_DIR=/tmp/screenshots
DOWNLOAD_DIR=/tmp/downloads
